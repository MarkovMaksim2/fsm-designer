{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FSM Verilog Designer",
  "version": "0.2.0",
  "identifier": "ru.itmo.fsmverilogdesigner",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run bundle:backend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FSM Verilog Designer",
        "width": 1600,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "bin/fsm-backend"
    ]
  }
}
